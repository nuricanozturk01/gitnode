# Local development profile — copy to application-local.yaml (gitignored).
#   cp application-local.yaml.example application-local.yaml
#
# Same key set as application.yaml; local dev values. Requires: make infra

server:
  port: 8080
  http2:
    enabled: true
  tomcat:
    connection-timeout: 20000
    max-part-count: 50
    accept-count: 50
  compression:
    enabled: true
    mime-types: application/json,application/xml,text/html,text/plain,text/css,application/javascript,image/svg+xml
    min-response-size: 1024

originhub:
  platform:
    admin-usernames: admin
  bootstrap:
    admin:
      username: admin
      password: Admin123
      enabled: true
  admin:
    enabled: true
    stats:
      cache-ttl-seconds: 300
    pgaudit:
      enabled: false
      log-directory: ${ORIGINHUB_ADMIN_PGAUDIT_LOG_DIRECTORY:${user.home}/.originhub/postgres-logs}
      max-scan-lines: 50000
      local-sync-container: originhub-postgres
      local-sync-on-startup: false
    modulith-events:
      enabled: true
  http:
    enabled: true
    port: 8080
  ssh:
    port: 2222
    host-path: ${originhub.git.repo-root}/.hosts
    host-key-path: ${originhub.ssh.host-path}/ssh_host_key
  jwt:
    secret: CHANGE_ME_local_dev_jwt_secret_min_32_chars
  cors:
    allowed-origins: http://localhost:4200,http://localhost:4300
  frontend:
    base-url: http://localhost:4200
  git:
    repo-root: ${user.home}/.originhub
  audit:
    enabled: true
  actions:
    enabled: true
    runner:
      heartbeat-timeout-seconds: 60
      job-timeout-minutes: 360
    artifacts:
      store-type: local
      local-path: ${originhub.git.repo-root}/artifacts
    cache:
      max-size-gb: 10
    secrets:
      encryption-key: ${ACTIONS_ENCRYPTION_KEY:CHANGE_ME_base64_32_byte_key}
  webhook:
    dlq:
      retry-cron: 0 */5 * * * *
      batch-size: 50
  sso:
    ldap:
      enabled: false
    saml:
      enabled: false
      registration-id: saml
      idp-metadata-uri: ""
      sp-entity-id: originhub
      email-attribute: email
      username-attribute: ""
      sp-signing-key-path: ${user.home}/.originhub/saml/sp-signing.key
      sp-signing-cert-path: ${user.home}/.originhub/saml/sp-signing.crt

app:
  schema: public

spring:
  cache:
    type: redis
  data:
    redis:
      host: localhost
      port: 6379
  threads:
    virtual:
      enabled: true
  jackson:
    deserialization:
      fail-on-null-for-primitives: false
  web:
    resources:
      static-locations: classpath:/static/
  modulith:
    events:
      jdbc:
        schema-initialization:
          enabled: false
      republish-outstanding-events-on-restart: true
      completion-mode: update

  datasource:
    url: jdbc:postgresql://localhost:5432/originhub
    username: admin
    password: admin123
    hikari:
      maximum-pool-size: 15
      minimum-idle: 3
      connection-timeout: 20000
      idle-timeout: 300000
      max-lifetime: 600000

  jpa:
    show-sql: false
    open-in-view: false
    generate-ddl: false
    hibernate:
      ddl-auto: none
      naming:
        physical-strategy: org.hibernate.boot.model.naming.PhysicalNamingStrategyStandardImpl
    properties:
      hibernate:
        globally_quoted_identifiers: true
        default_schema: ${app.schema}

  servlet:
    multipart:
      max-file-size: 5GB
      max-request-size: 6GB

  flyway:
    enabled: true
    schemas: public
    default-schema: public

  security:
    oauth2:
      client:
        registration:
          google:
            client-id: ${OAUTH2_GOOGLE_CLIENT_ID:}
            client-secret: ${OAUTH2_GOOGLE_CLIENT_SECRET:}
            scope: profile, email
            redirect-uri: "{baseUrl}/login/oauth2/code/google"
            authorization-grant-type: authorization_code
            client-name: Google
          github:
            client-id: ${OAUTH2_GITHUB_CLIENT_ID:}
            client-secret: ${OAUTH2_GITHUB_CLIENT_SECRET:}
            scope: profile, email
            redirect-uri: "{baseUrl}/login/oauth2/code/github"
            authorization-grant-type: authorization_code
            client-name: Github
          gitlab:
            client-id: ${OAUTH2_GITLAB_CLIENT_ID:}
            client-secret: ${OAUTH2_GITLAB_CLIENT_SECRET:}
            scope: read_user, email
            redirect-uri: "{baseUrl}/login/oauth2/code/gitlab"
            authorization-grant-type: authorization_code
            client-name: GitLab
        provider:
          google:
            authorization-uri: https://accounts.google.com/o/oauth2/v2/auth
            token-uri: https://oauth2.googleapis.com/token
            user-info-uri: https://openidconnect.googleapis.com/v1/userinfo
            user-name-attribute: sub
          github:
            authorization-uri: https://github.com/login/oauth/authorize
            token-uri: https://github.com/login/oauth/access_token
            user-info-uri: https://api.github.com/user
            user-name-attribute: id
          gitlab:
            authorization-uri: https://gitlab.com/oauth/authorize
            token-uri: https://gitlab.com/oauth/token
            user-info-uri: https://gitlab.com/api/v4/user
            user-name-attribute: id

resilience4j:
  circuitbreaker:
    configs:
      webhook-delivery:
        register-health-indicator: true
        sliding-window-type: COUNT_BASED
        sliding-window-size: 10
        failure-rate-threshold: 50
        slow-call-duration-threshold: 10s
        slow-call-rate-threshold: 80
        wait-duration-in-open-state: 60s
        permitted-number-of-calls-in-half-open-state: 3
        automatic-transition-from-open-to-half-open-enabled: true
    instances:
      saml-metadata:
        register-health-indicator: true
        sliding-window-type: COUNT_BASED
        sliding-window-size: 5
        failure-rate-threshold: 60
        wait-duration-in-open-state: 30s
        permitted-number-of-calls-in-half-open-state: 2
        automatic-transition-from-open-to-half-open-enabled: true

management:
  endpoints:
    web:
      exposure:
        include: health,info,metrics,prometheus,circuitbreakers
      base-path: /actuator
  endpoint:
    health:
      show-details: when-authorized
    prometheus:
      enabled: ${ORIGINHUB_OBSERVABILITY_ENABLED:true}
  prometheus:
    metrics:
      export:
        enabled: ${ORIGINHUB_OBSERVABILITY_ENABLED:true}
  metrics:
    tags:
      application: originhub

logging:
  level:
    root: warn
    org.apache.sshd.server.session.ServerSessionImpl: error
    com.nuricanozturk.originhub.ssh: info
    com.nuricanozturk.originhub: info
