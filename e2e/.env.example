# Copy to e2e/.env for local runs (gitignored).

# API target (CI sets these in the workflow; optional locally)
ORIGINHUB_API_BASE_URL=http://localhost:8080
ORIGINHUB_FRONTEND_BASE_URL=http://localhost:4200

# Optional: use existing accounts instead of auto-register in global-setup.
# Set both username and password for each role, or leave both unset for that role.
E2E_OWNER_USERNAME=
E2E_OWNER_PASSWORD=
E2E_INTRUDER_USERNAME=
E2E_INTRUDER_PASSWORD=

# Optional: force teardown to skip DELETE /api/users/me (auto-set when any credentials above are set)
# E2E_PRESERVE_USERS=1

# SAML scenario (scn-api-saml-login.spec.ts) — local only; skipped unless enabled
# E2E_SAML_ENABLED=1
# E2E_ADMIN_USERNAME=admin
# E2E_ADMIN_PASSWORD=Admin123

# LDAP scenario (scn-api-ldap-login.spec.ts) — local only; skipped unless enabled
# Requires OpenLDAP test server (container listens on 10389 — map host 389:10389, NOT 389:389):
#   make ldap-up
# or: docker run -d --name originhub-ldap -p 389:10389 ghcr.io/rroemhild/docker-test-openldap:master
# E2E_LDAP_ENABLED=1
# E2E_LDAP_URL=ldap://localhost:389
# E2E_LDAP_DOMAIN=planetexpress.com
# E2E_LDAP_TEST_USERNAME=fry
# E2E_LDAP_TEST_PASSWORD=fry
# E2E_LDAP_TEST_EMAIL=fry@planetexpress.com
