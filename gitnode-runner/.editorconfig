# EditorConfig for gitnode-runner (Go module).
# See https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[{*.yml,*.yaml}]
indent_size = 2

[*.md]
max_line_length = off
trim_trailing_whitespace = false

[*.go]
indent_style = tab

[{go.mod,go.sum}]
indent_style = tab

[Makefile]
indent_style = tab
