{
  "name": "originhub-admin-panel",
  "version": "1.0.0",
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "private": true,
  "scripts": {
    "ng": "ng",
    "prestart": "node set-env.js",
    "start": "ng serve",
    "build": "node set-env.js && ng build",
    "lint": "ng lint",
    "lint-fix": "ng lint --fix",
    "build:prod": "node set-env.js && ng build --configuration production",
    "format": "prettier --write \"src/**/*.{ts,html,css,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css,scss}\""
  },
  "dependencies": {
    "@angular/common": "^21.2.14",
    "@angular/compiler": "^21.2.14",
    "@angular/core": "^21.2.14",
    "@angular/forms": "^21.2.14",
    "@angular/platform-browser": "^21.2.14",
    "@angular/router": "^21.2.14",
    "@tailwindcss/postcss": "^4.3.0",
    "daisyui": "^5.5.20",
    "dotenv": "^17.4.2",
    "lucide-angular": "^0.575.0",
    "postcss": "^8.5.15",
    "rxjs": "~7.8.2",
    "tailwindcss": "^4.3.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "21.2.0",
    "@angular/build": "^21.2.13",
    "@angular/cli": "^21.2.13",
    "@angular/compiler-cli": "^21.2.14",
    "@eslint/js": "^9.39.4",
    "angular-eslint": "21.2.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.50.1"
  }
}
