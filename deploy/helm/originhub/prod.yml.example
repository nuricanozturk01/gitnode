# Production overlay — copy to prod.yml and fill base64 secrets:
#   echo -n 'your-secret' | base64
#
# helm upgrade --install originhub . -f values.yml -f prod.yml -n originhub
imageTag: "2.0.1"

domain:
  apiHost: api.originhub.example.com
  frontendUrl: https://originhub.example.com
  grafanaHost: grafana.originhub.example.com
  extraCorsOrigins: []

common:
  secrets:
    ORIGINHUB_JWT_SECRET:

originhub:
  secrets:
    OAUTH2_GOOGLE_CLIENT_ID:
    OAUTH2_GOOGLE_CLIENT_SECRET:
    OAUTH2_GITHUB_CLIENT_ID:
    OAUTH2_GITHUB_CLIENT_SECRET:
    OAUTH2_GITLAB_CLIENT_ID:
    OAUTH2_GITLAB_CLIENT_SECRET:
    ORIGINHUB_BOOTSTRAP_ADMIN_PASSWORD:

postgres:
  secrets:
    DB_DATABASE:
    DB_USERNAME:
    DB_PASSWORD:

monitoring:
  enabled: true
  secrets:
    GF_SECURITY_ADMIN_PASSWORD:

ingress:
  tls:
    enabled: true
  certManager:
    clusterIssuer: letsencrypt-prod
